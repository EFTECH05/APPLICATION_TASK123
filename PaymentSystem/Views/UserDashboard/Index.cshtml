@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Dashboard";

    // SAFE SESSION HANDLING
    var userName = Context.Session.GetString("User");
    var role = Context.Session.GetString("Role");

    if (string.IsNullOrEmpty(userName)) userName = "Guest User";
    if (string.IsNullOrEmpty(role)) role = "User";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
    background: #f5f7fb;
    margin: 0;
    }

    /* CARD */
    .bank-card {
    background: linear-gradient(135deg, #0d6efd, #0046b3);
    color: white;
    border-radius: 18px;
    padding: 22px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .card-box {
    border-radius: 16px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.06);
    background: white;
    padding: 18px;
    }

    .section-title {
    font-weight: 600;
    margin-bottom: 10px;
    }

    /* CHART */
    canvas {
    width: 100% !important;
    height: auto !important;
    }

    /* QUICK BUTTONS */
    .quick-btn {
    width: 100%;
    border-radius: 12px;
    padding: 10px;
    font-weight: 600;
    }

    /* TRANSACTIONS */
    .item {
    display: flex;
    justify-content: space-between;
    padding: 10px;
    border-bottom: 1px solid #eee;
    }

    /* RESPONSIVE FIX */
    @@media (max-width: 768px) {

    .row {
    flex-direction: column;
    }

    .bank-card {
    margin-bottom: 15px;
    }

    .card-box {
    margin-bottom: 15px;
    }
    }
</style>

<div class="container">

    <!-- TOP -->
    <div class="row g-4">

        <!-- USER CARD -->
        <div class="col-md-6">
            <div class="bank-card">

                <small>GlobalTrust Bank</small>

                <h5>Welcome, @userName 👋</h5>
                <small>Role: @role</small>

                <h3 class="mt-3">**** **** **** 4821</h3>
                <small>Account Active</small>

            </div>
        </div>

        <!-- BALANCE -->
        <div class="col-md-6">
            <div class="card-box">

                <h6 class="text-muted">Available Balance</h6>
                <h2 class="text-primary">R 12,500.75</h2>
                <p class="text-success">✔ Active Account</p>

                <div class="row g-2 mt-2">

                    <div class="col-4">
                        <button class="btn btn-primary quick-btn">💸 Send</button>
                    </div>

                    <div class="col-4">
                        <button class="btn btn-success quick-btn">📥 Request</button>
                    </div>

                    <div class="col-4">
                        <button class="btn btn-dark quick-btn">💳 Pay</button>
                    </div>

                </div>

            </div>
        </div>

    </div>

    <!-- TRANSFER -->
    <div class="card-box mt-4">

        <h5 class="section-title">💸 Transfer Money</h5>

        <input class="form-control mb-2" placeholder="Recipient Name" />
        <input class="form-control mb-2" placeholder="Account Number" />
        <input class="form-control mb-2" placeholder="Bank Name" />
        <input class="form-control mb-2" placeholder="Amount (ZAR)" />

        <button class="btn btn-primary w-100">
            Confirm Transfer
        </button>

    </div>

    <!-- TRANSACTIONS -->
    <div class="card-box mt-4">

        <h5 class="section-title">📊 Recent Transactions</h5>

        <div class="item">
            <span>Salary Deposit</span>
            <span class="text-success">+ R8,000</span>
        </div>

        <div class="item">
            <span>Electricity Bill</span>
            <span class="text-danger">- R350</span>
        </div>

        <div class="item">
            <span>Online Purchase</span>
            <span class="text-danger">- R1,200</span>
        </div>

    </div>

    <!-- CHART -->
    <div class="card-box mt-4">
        <h5 class="section-title">📈 Transfers Overview</h5>
        <canvas id="transferChart"></canvas>
    </div>

</div>

<script>
    new Chart(document.getElementById('transferChart'), {
    type: 'line',
    data: {
    labels: ['Jan','Feb','Mar','Apr','May','Jun'],
    datasets: [{
    label: 'Transfers',
    data: [1200,1900,3000,2500,4000,3200],
    borderColor: '#0d6efd',
    backgroundColor: 'rgba(13,110,253,0.1)',
    fill: true,
    tension: 0.4
    }]
    }
    });
</script>