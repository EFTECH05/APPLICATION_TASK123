@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: linear-gradient(135deg, #eef3ff, #f8f9fa);
    }

    .register-card {
        max-width: 480px;
        margin: 70px auto;
        padding: 30px;
        border-radius: 18px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.12);
        animation: fadeIn 0.6s ease-in-out;
    }

    .btn {
        border-radius: 30px;
    }

    .form-control {
        border-radius: 12px;
        padding: 10px;
    }

    .highlight {
        color: #0d6efd;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(25px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="register-card">

    <h3 class="text-center mb-2">Create Account 🚀</h3>
    <p class="text-center text-muted">
        Join <span class="highlight">GlobalTrust</span> secure banking system
    </p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger text-center">
            @ViewBag.Error
        </div>
    }

    <form method="post" asp-controller="Auth" asp-action="Register">

        <div class="mb-3">
            <label>Full Name</label>
            <input name="fullName" class="form-control" placeholder="Enter your full name" />
        </div>

        <div class="mb-3">
            <label>Username</label>
            <input name="username" class="form-control" placeholder="Choose username" />
        </div>

        <div class="mb-3">
            <label>Email</label>
            <input name="email" type="email" class="form-control" placeholder="Enter email address" />
        </div>

        <div class="mb-3">
            <label>Password</label>
            <input name="password" type="password" class="form-control" placeholder="Create password" />
        </div>

        <div class="mb-3">
            <label>Confirm Password</label>
            <input name="confirmPassword" type="password" class="form-control" placeholder="Confirm password" />
        </div>

        <button class="btn btn-primary w-100 mt-2">
            Create Account
        </button>

    </form>

    <p class="text-center mt-3">
        Already have an account?
        <a asp-controller="Auth" asp-action="Login">Login</a>
    </p>

</div>