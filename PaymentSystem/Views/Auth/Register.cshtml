@model PaymentSystem.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: linear-gradient(135deg, #0d6efd, #e9f2ff);
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    .page-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .register-wrapper {
        width: 100%;
        max-width: 1000px;
        display: flex;
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.25);
    }

    /* LEFT PANEL */
    .left-panel {
        flex: 1;
        background: linear-gradient(135deg, #0d6efd, #003a99);
        color: white;
        padding: 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .left-panel h1 {
            font-weight: 700;
            font-size: 32px;
            margin-bottom: 15px;
        }

        .left-panel p {
            opacity: 0.9;
            font-size: 15px;
        }

        .left-panel ul {
            margin-top: 20px;
            padding-left: 18px;
        }

        .left-panel li {
            margin-bottom: 8px;
        }

    .brand {
        font-size: 22px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .highlight {
        color: #ffd700;
    }

    /* RIGHT PANEL */
    .right-panel {
        flex: 1;
        padding: 50px;
    }

        .right-panel h3 {
            font-weight: 600;
            margin-bottom: 20px;
        }

    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #ddd;
    }

        .form-control:focus {
            border-color: #0d6efd;
            box-shadow: none;
        }

    label {
        font-weight: 500;
        margin-bottom: 5px;
    }

    .btn-primary {
        border-radius: 30px;
        padding: 12px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-primary:hover {
            background-color: #0046b3;
        }

    .alert {
        border-radius: 10px;
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .register-wrapper {
            flex-direction: column;
        }

        .left-panel {
            text-align: center;
            padding: 30px;
        }

        .right-panel {
            padding: 30px;
        }
    }
</style>

<div class="page-wrapper">

    <div class="register-wrapper">

        <!-- ================= LEFT ================= -->
        <div class="left-panel">

            <div class="brand">
                💳 GlobalTrust Bank
            </div>

            <h1>Create Your Secure Account</h1>

            <p>
                Join a modern banking system built for fast,
                secure and global transactions.
            </p>

            <ul>
                <li>✔ Instant international transfers</li>
                <li>✔ Secure encrypted accounts</li>
                <li>✔ 24/7 online banking access</li>
            </ul>

        </div>

        <!-- ================= RIGHT ================= -->
        <div class="right-panel">

            <h3>Create Account</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post">

                <div class="mb-3">
                    <label>Full Name</label>
                    <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="john@email.com" />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <div class="mb-3">
                    <label>Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                </div>

                <button class="btn btn-primary w-100 mt-2">
                    Create Account
                </button>

            </form>

            <p class="text-center mt-3">
                Already have an account?
                <a asp-controller="Auth" asp-action="Login">Login</a>
            </p>

        </div>

    </div>

</div>