@model List<PaymentSystem.Models.User>

<h2>📩 Pending Update Requests</h2>

<table class="table table-bordered">

    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>@user.Status</td>

                <td>
                    <a asp-action="ApproveUpdate"
                           asp-route-id="@user.Id"
                           class="btn btn-success">
                        Approve
                    </a>
                </td>
            </tr>
        }

    </tbody>

</table>