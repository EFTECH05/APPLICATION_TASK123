@{
    ViewData["Title"] = "Home Page";
}

<div class="inline-flex" style="margin-top:150px;">
    <div class="text-start">
        <h1 class="display-6">Transform</h1>
        <p class="display-6">the way you</p>
        <p class="display-6">handle <span class="blue">money </span> </p>
    </div>
</div>

<div class="d-flex align-items-start">

    <!-- Left side -->
    <div>
        <img src="~/image/image_1.jpeg" style="width:460px;height:550px;" />
    </div>

    <!-- Right side (pushed far right) -->
    <div class="ms-auto">
        <div class="card shadow-sm" style="width:490px;">
            <div class="card-body">
                <!-- your form here -->
                <form method="post" action="/home/registerVenue" enctype="multipart/form-data">
                    <!-- Venue Name -->
                    <div class="mb-3">
                        <label for="VenueName" class="form-label blue">Full Name</label>
                        <input id="VenueName" name="VenueName" type="text" class="form-control text_rm-border" placeholder="Please Enter your Full Name" required />
                    </div>

                    <!-- Location -->
                    <div class="mb-3">
                        <label for="Location" class="form-label blue">ID Number</label>
                        <input id="Location" name="Location" type="text" class="form-control text_rm-border" placeholder="Please Enter your ID Number" required />
                    </div>
                    <!-- Capacity -->
                    <div class="mb-3">
                        <label for="Capacity" class="form-label blue">Account Number</label>
                        <input id="Location" name="Location" type="text" class="form-control text_rm-border" placeholder="Please Enter your Account Number" required />
                    </div>
                    <!-- Image Upload -->
                    <div class="mb-3">
                        <label for="ImageFile" class="form-label blue">Password </label>
                        <input id="Location" name="Location" type="text" class="form-control text_rm-border" placeholder="Please Enter your Password" required />
                    </div>
                    <div class="mb-3">
                        <label for="" class="form-label blue">Don't have an account?' </label>
                    </div>
                    <div class="justify-content-center">
                        <div class="d-flex justify-content-center">
                            <a class="nav-link text-white text-center bg-primary rounded-pill px-5 py-2">Register</a>
                        </div>
                    </div>
                    <!-- Buttons -->
                    @*<div class="d-flex justify-content-between">
                        <input type="reset" class="btn btn-secondary" value="Reset" />
                        <input type="submit" class="btn btn-primary" value="Submit" />
                    </div>*@
                </form>
            </div>
        </div>
    </div>
</div>
<div class="d-flex align-items-start" style="margin-top:20px;">
    <div class="justify-content-center" style="width:450px;">
        <div class="d-flex justify-content-center">
            <a class="nav-link text-white text-center bg-primary rounded-pill px-5 py-2">Get Started</a>
        </div>
        <div style="margin-top:150px;">
            <p class="display-4 blue">
                Why choose us?
            </p>
        </div>
        <div style="margin-top:80px;">
            <ul>
                <li>
                    Link up top 5 free pockets to your Account.
                </li>
                <li>
                    Enjoy the lowest banking fees and incredible value.
                </li>
                <li>
                    Easy-to-earn Audacious Rwards points
                </li>
            </ul>
        </div>
        <div class="me-auto" style="width:300px;">
            <div class="text-center" style="margin-top:180px;">
               <h5>Secure your financial</h5>
                <h5>future with us!</h5>
                <p class="text-center">Let our app handle your transfer while</p>
                <p class="text-center">you focus on things that matter the most. </p>
            </div>
        </div>
    </div>

    <div class="ms-auto">
        <div class="card shadow-lg" style="margin-top:60px;">
            <img src="~/image/image_3.jpeg" style="width:760px;height:710px;" />
        </div>
    </div>
</div>

<div class="d-flex align-items-start" style="margin-top:20px;">
    <div class="card shadow-lg" style="margin-top:60px;">
        <img src="~/image/image_4.jpeg" style="width:400px;height:430px;" />
    </div>
    <div class="ms-auto">
        <div class="d-flex justify-content-start" style="width:765px;margin-top:80px;">
            <p class="display-4 blue">
                Download the GlobalTrust
            </p>
        </div>
        <div class="row-cols-1">
            <p class="display-4 blue">
                bank app
            </p>
        </div>
        <div class="row-cols-1">
            <p class="row">your banking made easier</p>
            <p class="row"> it's like having your own bank in your pocket.</p>
            <p class="row">Access your accounts24/7, wherever you are. it's secure and super convenient</p>
        </div>
    </div>
</div>

